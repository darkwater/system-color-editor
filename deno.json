{
  "tasks": {
    "check": "deno check main.ts",
    "build": "deno bundle --platform browser --output main.js main.ts",
    "watch": "deno bundle --watch --platform browser --output main.js main.ts",
    "serve": "deno run --allow-net --allow-read jsr:@std/http/file-server ."
  },
  "compilerOptions": {
    "lib": ["dom", "dom.iterable", "deno.ns"]
  },
  "fmt": {
    "lineWidth": 100,
    "indentWidth": 2
  },
  "lint": {
    "rules": {
      "tags": ["recommended"],
      "exclude": ["no-explicit-any"]
    }
  }
}
